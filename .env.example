# Strapi CMS environment variables — copy to .env and fill in your values
# See ENV_SETUP.md at the project root for full documentation.

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337

# ── Security Keys (REQUIRED — generate new values for production) ──
# node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
APP_KEYS="CHANGE_ME_1,CHANGE_ME_2"
API_TOKEN_SALT=CHANGE_ME
ADMIN_JWT_SECRET=CHANGE_ME
TRANSFER_TOKEN_SALT=CHANGE_ME
JWT_SECRET=CHANGE_ME

# ── Database: PostgreSQL (production) ─────────────────────────
# DATABASE_CLIENT=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=chetnaverse_strapi
# DATABASE_USERNAME=strapi_user
# DATABASE_PASSWORD=
# DATABASE_SSL=false

# ── Email: SMTP ───────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_REPLY_TO=

# ── Media Upload: Cloudinary ──────────────────────────────────
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# ── Public URL (production) ───────────────────────────────────
# STRAPI_URL=https://cms.chetnaverse.com
