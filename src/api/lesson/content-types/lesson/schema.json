{
  "kind": "collectionType",
  "collectionName": "lessons",
  "info": {
    "singularName": "lesson",
    "pluralName": "lessons",
    "displayName": "Lesson",
    "description": "Individual lessons within a module"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "order": {
      "type": "integer"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "video",
        "quiz",
        "text"
      ],
      "default": "video"
    },
    "bunnyVideoId": {
      "type": "string"
    },
    "durationSeconds": {
      "type": "integer",
      "default": 0
    },
    "module": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::module.module",
      "inversedBy": "lessons"
    }
  }
}
